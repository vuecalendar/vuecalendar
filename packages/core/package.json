{
  "name": "@vuecalendar/core",
  "version": "1.0.9",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.es.js",
  "description": "Vue 3 calendar component - no external UI dependencies",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.cjs"
    },
    "./tokens.css": "./src/styles/tokens.css",
    "./nav-transition.css": "./src/styles/nav-transition.css"
  },
  "files": [
    "src",
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "temporal-polyfill": "^0.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "vite": "^5.4.0",
    "vue": "^3.5.0"
  },
  "scripts": {
    "build": "vite build"
  },
  "keywords": [
    "vue",
    "calendar",
    "scheduler",
    "events",
    "vue3"
  ],
  "license": "MIT"
}
